%% 包调用依赖图 (mfg_erp_sql)
%% 实线 = 业务调用，虚线 = 调基础包(exc/util)，所有包都依赖 const 常量(未画)
%% sched 通过 DBMS_SCHEDULER 作业体字符串调 mrp/forecast(运行期，非编译期依赖)

flowchart TD
    subgraph 基础
        const[const_pkg<br/>常量]
        exc[exc_pkg<br/>异常+自治事务日志]
        util[util_pkg<br/>业务日期/单位/参数重载]
    end

    subgraph 主数据
        item[item_pkg<br/>物料+分类树+对象多态]
        bom[bom_pkg<br/>BOM 递归展开/版本比对/卷算]
    end

    subgraph 业务
        inv[inventory_pkg<br/>收发/FIFO/批量收货]
        cost[costing_pkg<br/>估值/落地成本/卷算回写]
        price[pricing_pkg<br/>阶梯定价]
        proc[procurement_pkg<br/>采购 PO 状态机]
        mrp[mrp_pkg<br/>物料需求计划]
        fc[forecast_pkg<br/>MODEL 预测/动态透视]
        rpt[report_pkg<br/>分析报表]
        sch[sched_pkg<br/>调度作业]
    end

    %% 业务调用
    cost --> bom
    proc --> inv
    mrp --> bom
    mrp --> inv
    rpt --> fc
    sch -.作业体.-> mrp
    sch -.作业体.-> fc

    %% 基础依赖(虚线，示意一组)
    util -.-> exc
    exc -.-> const
    item -.-> util
    bom -.-> util
    inv -.-> util
    price -.-> util
    fc -.-> util

    %% 触发器入口
    vtrg([trg_v_item_full<br/>INSTEAD OF]) --> item
    itrg([trg_inv_txn<br/>compound]) -.审计.-> auditlog[(t_audit_log)]

    %% 独立函数(SQL 直调，不被包体依赖)
    fns[["fn_uom_convert / fn_abc_class<br/>fn_landed_cost / fn_bom_unit_cost(递归)"]]
