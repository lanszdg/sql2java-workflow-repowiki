      "PL",
      "SQL"
    ],
    "service_name": [],
    "service_category": []
  },
  "technicalSlugPatterns": [
    "[a-z]+(?:-[a-z0-9]+){1,}"
  ],
  "functionNameRejectPatterns": [
    "[#_]",
    "--?\\d+$",
    "PROCEDURE$",
    "FUNCTION$"
  ],
  "businessNameRejectPatterns": [
    "[#_]",
    "[a-z]+(?:-[a-z0-9]+){1,}"
