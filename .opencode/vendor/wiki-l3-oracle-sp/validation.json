{
  "_comment": "Oracle 存过 FSD skill 语义校验口径。功能类型固定为存过-PL/SQL，服务=Package，功能=Procedure/Function。",
  "localeRequire": "zh",
  "serviceRequiredFields": [
    "service_name",
    "service_category",
    "impl_qn",
    "iface_qn",
    "config",
    "version"
  ],
  "functionRequiredFields": [
    "business_name",
    "function_type",
    "function_name",
    "summary",
    "entry",
    "impl_qn",
    "method",
    "module"
  ],
  "rejectRawIdentifierResidue": true,
  "rawIdentifierFields": [
    "function_name"
  ],
  "rawIdentifierRejectPattern": "_|[a-z][A-Z]|[A-Z][a-z]+[A-Z]|(Service|Impl|Controller|Facade|Manager|Provider|Consumer|Mapper|Repository|Client|Api|DTO|DO|VO|BO|PKG|PROCEDURE|FUNCTION)$|^[a-z]{3,}$",
  "softCheckTypes": [
    "raw_identifier",
    "weak_name",
    "summary_short",
    "locale_zh",
    "summary_name_consistency"
  ],
  "minSummaryChars": 12,
  "emptySummaryValues": [
    "待补充",
    "需人工复核",
    "无"
  ],
  "hardRejectPatternsByField": {
    "service_category": [
      "(^|[\\\\/])(未分类|需业务复核|需人工复核|待补充|无)([\\\\/]|$)"
    ],
    "business_name": [
      "(^|[\\\\/])(未分类|需业务复核|需人工复核|待补充|无)([\\\\/]|$)"
    ],
    "function_type": [
      "^(?!存过-PL/SQL$).*$"
    ]
  },
  "functionTypeByEntryType": {
    "procedure": "存过-PL/SQL",
    "*": "存过-PL/SQL"
  },
  "rejectSummaryPatterns": [
    "^(待补充|需人工复核|无)$",
    "^(调用|执行).{0,6}$"
  ],
  "requireServiceRowReference": true,
  "uniqueFunctionDocName": true,
  "functionDocSections": [
    "概览",
    "表结构映射",
    "依赖分析",
    "业务规则",
    "控制流与异常",
    "特殊语法转化规约"
  ],
