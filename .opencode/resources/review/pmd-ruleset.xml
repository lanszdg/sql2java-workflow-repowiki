<?xml version="1.0"?>
<ruleset name="sql2java-review"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
  <!--
    sql2java review 静态扫描 — PMD 规则（#15 集合与异常：空 catch / 未关资源 / 空语句）。
    PMD 6.55.0（maven-pmd-plugin 3.21.2 自带，JDK 8 基线）。引擎自带，绝对路径传 -Drulesets。
    #16 版本合规（Java 9+ API）不走 PMD XPath，归 grep 脚本 scanJava9PlusApi（脱离 mvn）。
  -->
  <description>sql2java review #15 collection-exception</description>

  <rule ref="category/java/errorprone.xml/EmptyCatchBlock"/>
  <rule ref="category/java/errorprone.xml/EmptyStatementNotInLoop"/>
  <rule ref="category/java/errorprone.xml/CloseResource"/>
  <rule ref="category/java/bestpractices.xml/UnusedLocalVariable"/>
</ruleset>
